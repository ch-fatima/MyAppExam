<?xml version="1.0" encoding="utf-8" ?>

<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      throwExceptions="true">

	<variable name="logDirectory" value="${basedir}/Logs" />

	<extensions>
		<add assembly="NLog.Slack" />
		<add assembly="NLog.Targets.Seq" />
	</extensions>

	<targets async="true">

		<!-- File -->
		<target name="textFile"
        xsi:type="File"
        fileName="${logDirectory}/log.${shortdate}.txt"
        layout="${longdate} ${threadid:padding=4} ${level:uppercase=true:padding=5} ${logger} ${message} ${exception:format=tostring}"
        createDirs="true"
        keepFileOpen="false"
        autoFlush="true" />

		<!-- Seq -->
		<target name="seq"
				xsi:type="Seq"
                serverUrl="http://seq"
				/>
	</targets>

	<rules>

		<!-- File logs -->
		<logger name="*" minlevel="Trace" writeTo="textFile" />

		<!-- Seq logs -->
		<logger name="*" minlevel="Info" writeTo="seq" />

	</rules>

</nlog>
